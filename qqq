// 使用示例
void demonstrateAutoMasking(SimpleStencilMaskRenderer& renderer, VkCommandBuffer cmdBuffer) {
    // 创建三个重叠的遮罩
    PolygonMask mask1, mask2, mask3;
    
    // 遮罩1: 大矩形
    mask1.vertices = {{100, 100}, {600, 100}, {600, 500}, {100, 500}};
    
    // 遮罩2: 与mask1部分重叠的圆形（用多边形近似）
    mask2.vertices = generateCircleVertices({400, 300}, 150, 32);
    
    // 遮罩3: 小矩形，与前面两个都重叠
    mask3.vertices = {{200, 200}, {500, 200}, {500, 400}, {200, 400}};
    
    // 开始遮罩渲染帧
    renderer.beginMaskFrame(cmdBuffer);
    
    // 应用三个遮罩 - Vulkan会自动处理叠加！
    renderer.applyMask(cmdBuffer, mask1, MaskOperation::ADD);
    renderer.applyMask(cmdBuffer, mask2, MaskOperation::ADD); 
    renderer.applyMask(cmdBuffer, mask3, MaskOperation::ADD);
    
    // 开始内容渲染
    renderer.beginContentRendering(cmdBuffer);
    
    // 绘制一些UI内容
    drawMyUIContent(cmdBuffer);
    
    // 结束
    renderer.endContentRendering(cmdBuffer);
}
